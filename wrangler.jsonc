{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "chest-so-site",
  "compatibility_date": "2026-06-30",
  "main": "./worker/index.ts",
  "observability": {
    "enabled": true,
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": true,
  },
  "compatibility_flags": ["nodejs_compat"],
}
